/**
 * Returns a greeting for the given name.
 *
 * @param name - The name to greet
 * @returns A greeting string
 *
 * @example
 * ```ts
 * greet("world"); // "Hello, world!"
 * ```
 */
export function greet(name: string): string {
  return `Hello, ${name}!`;
}

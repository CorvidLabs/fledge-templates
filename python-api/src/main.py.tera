from fastapi import FastAPI

app = FastAPI(
    title="{{ project_name_pascal }}",
    description="{{ description }}",
    version="0.1.0",
)


@app.get("/")
async def root() -> dict[str, str]:
    return {"message": "Hello from {{ project_name }}"}


@app.get("/health")
async def health() -> dict[str, str]:
    return {"status": "ok"}

[package]
name = "{{ project_name }}"
version = "0.1.0"
edition = "2024"
description = "{{ description }}"
license = "{{ license }}"
repository = "https://github.com/{{ github_org }}/{{ project_name }}"
readme = "README.md"
keywords = []
categories = []

[dependencies]
serde = { version = "1", features = ["derive"], optional = true }

[dev-dependencies]

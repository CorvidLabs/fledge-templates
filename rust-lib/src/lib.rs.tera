//! {{ description }}

/// Add two numbers together.
///
/// # Examples
///
/// ```
/// assert_eq!({{ project_name_snake }}::add(2, 3), 5);
/// ```
pub fn add(a: i64, b: i64) -> i64 {
    a + b
}

#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn test_add() {
        assert_eq!(add(2, 3), 5);
    }
}
